# Firebase (required) – mirror of corsa-next's NEXT_PUBLIC_FIREBASE_* vars
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456

# AppSync (required)
VITE_APPSYNC_ENDPOINT=https://xxxxxxxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
# For real-time subscriptions (wss://)
VITE_APPSYNC_REALTIME_ENDPOINT=wss://xxxxxxxxxxxxxxx.appsync-realtime-api.us-east-1.amazonaws.com/graphql

# CDN base URL for user-uploaded images (optional)
VITE_CDN_BASE=https://your-cdn.cloudfront.net
